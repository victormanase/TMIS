# Copy this to .env — deploy.sh fills this automatically.
# These values are used by docker-compose.yml.

# Public IP or domain of your server (no http://, no trailing slash)
SERVER_IP=your-server-ip-or-domain

# PostgreSQL password (auto-generated by deploy.sh)
DB_PASSWORD=change-this-to-a-strong-password

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-this-access-secret-min-48-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-48-chars

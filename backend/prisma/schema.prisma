generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  VIEWER
}

enum UnitType {
  APARTMENT
  STUDIO
  AIRBNB
  OTHER
}

enum PaymentType {
  RENT
  SERVICE_CHARGE
  AIRBNB
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String    @unique
  phone             String?
  password          String
  role              Role      @default(VIEWER)
  isActive          Boolean   @default(true)
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  payments   Payment[]
  auditLogs  AuditLog[]

  @@map("users")
}

model Property {
  id          String    @id @default(cuid())
  name        String
  location    String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  units Unit[]

  @@map("properties")
}

model Unit {
  id            String    @id @default(cuid())
  propertyId    String
  unitNumber    String
  unitType      UnitType
  bedrooms      Int
  monthlyRent   Decimal?  @db.Decimal(12, 2)
  dailyRate     Decimal?  @db.Decimal(12, 2)
  serviceCharge Decimal   @default(0) @db.Decimal(12, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  property    Property           @relation(fields: [propertyId], references: [id])
  assignments TenantAssignment[]
  payments    Payment[]
  bookings    AirBnBBooking[]

  @@unique([propertyId, unitNumber])
  @@map("units")
}

model Tenant {
  id         String    @id @default(cuid())
  firstName  String
  middleName String?
  lastName   String
  phone      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  assignments TenantAssignment[]
  payments    Payment[]
  bookings    AirBnBBooking[]

  @@map("tenants")
}

model TenantAssignment {
  id           String    @id @default(cuid())
  unitId       String
  tenantId     String
  checkInDate  DateTime
  checkOutDate DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  unit   Unit   @relation(fields: [unitId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_assignments")
}

model Payment {
  id           String      @id @default(cuid())
  tenantId     String
  unitId       String
  paymentType  PaymentType
  amount       Decimal     @db.Decimal(12, 2)
  paymentDate  DateTime
  periodStart  DateTime
  periodEnd    DateTime
  recordedById String
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  unit       Unit   @relation(fields: [unitId], references: [id])
  recordedBy User   @relation(fields: [recordedById], references: [id])

  @@map("payments")
}

model AirBnBBooking {
  id          String   @id @default(cuid())
  unitId      String
  tenantId    String
  startDate   DateTime
  endDate     DateTime
  days        Int
  dailyRate   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount Decimal  @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit   Unit   @relation(fields: [unitId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("airbnb_bookings")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
